{
  "name": "ace-ai-acode-plugin",
  "version": "0.8.44",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "node tools/build.mjs",
    "syntax": "npm run build && node -c plugin/main.js",
    "lint": "eslint \"src/**/*.js\" \"tools/**/*.mjs\"",
    "format": "prettier --check \"src/**/*.js\" \"tools/**/*.mjs\" \"*.js\" \"*.json\" \"plugin/*.md\" \"plugin/*.json\"",
    "format:write": "prettier --write \"src/**/*.js\" \"tools/**/*.mjs\" \"*.js\" \"*.json\" \"plugin/*.md\" \"plugin/*.json\"",
    "check": "npm run syntax && npm run lint && npm run format"
  },
  "devDependencies": {
    "eslint": "^10.3.0",
    "prettier": "^3.8.3"
  },
  "author": "Er Rickow",
  "license": "Apache-2.0",
  "keywords": [
    "acode",
    "acode-plugin",
    "ai",
    "coding-assistant",
    "agent",
    "diff",
    "neosantara"
  ]
}
